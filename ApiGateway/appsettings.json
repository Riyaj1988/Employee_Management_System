{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Jwt": {
    "Key": "THIS_IS_A_VERY_SECURE_KEY_123456",
    "Issuer": "AuthService",
    "Audience": "EmployeeManagementSystem"
  },

  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "Match": { "Path": "/auth/{**catch-all}" },
        "ClusterId": "auth-cluster"
      },
      "employee-route": {
        "Match": { "Path": "/employees/{**catch-all}" },
        "ClusterId": "employee-cluster",
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "department-route": {
        "Match": { "Path": "/departments/{**catch-all}" },
        "ClusterId": "department-cluster",
        "AuthorizationPolicy": "AuthenticatedUser"
      },
      "logging-route": {
        "Match": { "Path": "/logging/{**catch-all}" },
        "ClusterId": "logging-cluster",
        "Transforms": [
          { "PathRemovePrefix": "/logging" }
        ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5001/" }
        }
      },
      "employee-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5002" }
        }
      },
      "department-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5182/" }
        }
      },
      "logging-cluster": {
        "Destinations": {
          "d1": { "Address": "http://localhost:5017/" }
        }
      }
    }
  }
}
